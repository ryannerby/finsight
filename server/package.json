{
  "name": "thesis-backend",
  "version": "1.0.0",
  "description": "Backend API for thesis project",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "supabase gen types typescript --local > src/types/supabase.ts",
    "seed": "tsx scripts/seedData.ts",
    "cleanup": "tsx scripts/cleanupDuplicates.ts",
    "cleanup:all": "tsx scripts/cleanupAll.ts",
    "add-analyses": "tsx scripts/addAnalyses.ts",
    "schemas:validate": "tsx src/services/validateSchemas.ts",
    "test:phase2": "node scripts/test-phase2.js",
    "test:phase4": "node scripts/test-upload-parsing.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.59.0",
    "@supabase/supabase-js": "^2.54.0",
    "@types/exceljs": "^0.5.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "puppeteer-core": "^24.16.1",
    "xlsx": "^0.18.5",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.10",
    "@types/papaparse": "^5.3.16",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
